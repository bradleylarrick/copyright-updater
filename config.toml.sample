Copyright = [
'Copyright (c) ${year} Company Name. All rights reserved.',
'',
'Licensed under the Apache License v2.0',
'https://www.apache.org/licenses/LICENSE-2.0']

#
# Valid Processors are:
#   - apt     (~~)
#   - bat     (REM)
#   - hashtag (#)
#   - java    (/* and */)
#   - xml     (<!-- and -->)
#
[[Extensions]]
Extension = '.hcl'
Processor = 'hashtag'
Protected = []

[[Extensions]]
Extension = '.scss'
Processor = 'java'
Protected = []
